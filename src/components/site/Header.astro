---
import { navigation } from "../../data/navigation";
---

<header class="py-7">
  <div class="mx-auto max-w-4xl px-6 flex items-center justify-between">
    <a href="/" class="text-[1.75rem] font-extrabold tracking-tight no-underline">
      <span class="text-text">Vi</span><span
        class="bg-gradient-to-br from-primary to-secondary bg-clip-text text-transparent"
        >Fi</span
      >
    </a>
    <nav class="hidden sm:flex items-center gap-6" aria-label="Main navigation">
      {
        navigation.map((item) => (
          <a
            href={item.href}
            class="text-sm text-muted hover:text-text transition-colors"
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
