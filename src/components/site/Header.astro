---
import { navigation } from "../../data/navigation";
---

<header class="py-7">
  <div class="mx-auto max-w-5xl px-6 flex items-center justify-between">
    <a href="/" class="text-[1.75rem] font-extrabold tracking-tight no-underline">
      <span class="text-text">Vi</span><span
        class="bg-gradient-to-br from-primary to-secondary bg-clip-text text-transparent"
        >Fi</span
      >
    </a>

    <nav class="hidden md:flex items-center gap-6" aria-label="Main navigation">
      {
        navigation.map((item) => (
          <a
            href={item.href}
            class="text-sm text-muted hover:text-text transition-colors"
          >
            {item.label}
          </a>
        ))
      }
      <a
        href="/#early-access"
        class="rounded-full bg-gradient-to-br from-primary to-secondary px-5 py-2 text-sm font-semibold text-white transition hover:opacity-90"
      >
        Get Early Access
      </a>
    </nav>

    <button
      id="mobile-menu-toggle"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span class="block h-0.5 w-6 bg-text transition-all duration-200" id="bar1"></span>
      <span class="block h-0.5 w-6 bg-text transition-all duration-200" id="bar2"></span>
      <span class="block h-0.5 w-6 bg-text transition-all duration-200" id="bar3"></span>
    </button>
  </div>

  <nav
    id="mobile-menu"
    class="hidden md:hidden border-t border-border mt-4"
    aria-label="Mobile navigation"
  >
    <div class="mx-auto max-w-5xl px-6 py-4 flex flex-col gap-3">
      {
        navigation.map((item) => (
          <a
            href={item.href}
            class="text-sm text-muted hover:text-text transition-colors py-1"
          >
            {item.label}
          </a>
        ))
      }
      <a
        href="/#early-access"
        class="mt-2 inline-block rounded-full bg-gradient-to-br from-primary to-secondary px-5 py-2.5 text-sm font-semibold text-white text-center transition hover:opacity-90"
      >
        Get Early Access
      </a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById("mobile-menu-toggle")!;
  const menu = document.getElementById("mobile-menu")!;
  const bar1 = document.getElementById("bar1")!;
  const bar2 = document.getElementById("bar2")!;
  const bar3 = document.getElementById("bar3")!;

  toggle.addEventListener("click", () => {
    const open = menu.classList.toggle("hidden");
    const isOpen = !open;
    toggle.setAttribute("aria-expanded", String(isOpen));
    bar1.style.transform = isOpen ? "rotate(45deg) translate(4px, 4px)" : "";
    bar2.style.opacity = isOpen ? "0" : "1";
    bar3.style.transform = isOpen ? "rotate(-45deg) translate(4px, -4px)" : "";
  });
</script>
