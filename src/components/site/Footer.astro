---
import { footerNavigation } from "../../data/navigation";
import { siteConfig } from "../../data/site";

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border pt-12 pb-8">
  <div class="mx-auto max-w-5xl px-6">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div>
        <a href="/" class="text-xl font-extrabold tracking-tight no-underline">
          <span class="text-text">Vi</span><span
            class="bg-gradient-to-br from-primary to-secondary bg-clip-text text-transparent"
            >Fi</span
          >
        </a>
        <p class="mt-3 text-sm text-muted leading-relaxed max-w-xs">
          {siteConfig.tagline}
        </p>
      </div>

      <!-- Footer sections -->
      {
        footerNavigation.map((section) => (
          <div>
            <h3 class="text-sm font-semibold text-text mb-3">{section.title}</h3>
            <ul class="space-y-2">
              {section.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-muted hover:text-text transition-colors"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="mt-12 border-t border-border pt-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-sm text-muted">
        &copy; {currentYear} ViFi. All rights reserved.
      </p>
      <a
        href={`mailto:${siteConfig.email}`}
        class="text-sm text-muted hover:text-text transition-colors"
      >
        {siteConfig.email}
      </a>
    </div>
  </div>
</footer>
