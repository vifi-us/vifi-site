---
const items = [
  { icon: "M12 8v4l3 3 M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z", text: "7-day free trial" },
  { icon: "M20 12V8H6a2 2 0 0 1 0-4h14v4 M20 12v4H6a2 2 0 0 1 0-4h14", text: "No credit card required" },
  { icon: "M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z", text: "Keep your own number" },
  { icon: "M18 6 6 18 M6 6l12 12", text: "Cancel anytime" },
];
---

<section class="pb-16 sm:pb-24">
  <div class="mx-auto max-w-4xl px-6">
    <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
      {
        items.map((item) => (
          <div class="flex items-center gap-2 text-sm text-muted">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-secondary"
            >
              <path d={item.icon} />
            </svg>
            {item.text}
          </div>
        ))
      }
    </div>
  </div>
</section>
