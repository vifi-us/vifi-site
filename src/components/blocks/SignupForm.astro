---
import { siteConfig } from "../../data/site";

const { googleForm } = siteConfig;
---

<section class="pb-20 sm:pb-28 text-center" id="early-access">
  <div class="mx-auto max-w-md px-6">
    <p class="mb-6 text-sm text-muted">Join the early access list</p>

    <form
      id="signup-form"
      action={googleForm.actionUrl}
      method="POST"
      target="form-iframe"
      class="flex flex-col gap-3"
    >
      <input
        type="text"
        name={googleForm.fields.name}
        placeholder="Name"
        required
        autocomplete="name"
        class="w-full rounded-xl border border-border bg-surface px-4 py-3 text-sm text-text placeholder:text-muted/60 outline-none transition focus:border-accent/50 focus:ring-1 focus:ring-accent/30"
      />
      <input
        type="email"
        name={googleForm.fields.email}
        placeholder="Work email"
        required
        autocomplete="email"
        class="w-full rounded-xl border border-border bg-surface px-4 py-3 text-sm text-text placeholder:text-muted/60 outline-none transition focus:border-accent/50 focus:ring-1 focus:ring-accent/30"
      />
      <input
        type="text"
        name={googleForm.fields.company}
        placeholder="Company (optional)"
        autocomplete="organization"
        class="w-full rounded-xl border border-border bg-surface px-4 py-3 text-sm text-text placeholder:text-muted/60 outline-none transition focus:border-accent/50 focus:ring-1 focus:ring-accent/30"
      />
      <button
        type="submit"
        class="mt-1 w-full cursor-pointer rounded-full bg-accent px-9 py-3.5 text-base font-semibold text-on-accent shadow-[0_4px_32px_var(--color-accent-glow)] transition hover:opacity-90 hover:-translate-y-0.5 hover:shadow-[0_8px_40px_var(--color-accent-glow-strong)] disabled:opacity-50 disabled:cursor-not-allowed disabled:translate-y-0"
      >
        Get Early Access
      </button>
      <p class="text-xs leading-relaxed text-muted">
        By submitting this form, you agree that ViFi may use your information to
        contact you about early access and product updates. This form is
        submitted through a third-party form processing service. See our
        <a href="/legal/privacy" class="underline underline-offset-2">Privacy Policy</a>
        and
        <a href="/legal/terms" class="underline underline-offset-2">Terms of Service</a>.
      </p>
    </form>

    <div id="signup-success" class="hidden">
      <div class="rounded-xl border border-accent/30 bg-accent/10 px-6 py-5">
        <p class="text-sm font-semibold text-accent">You're on the list!</p>
        <p class="mt-1 text-sm text-muted">
          We'll reach out when your spot is ready.
        </p>
      </div>
    </div>

    <iframe name="form-iframe" class="hidden" tabindex="-1" aria-hidden="true"
    ></iframe>
  </div>
</section>

<script>
  const form = document.getElementById("signup-form") as HTMLFormElement;
  const success = document.getElementById("signup-success")!;

  form.addEventListener("submit", () => {
    setTimeout(() => {
      form.classList.add("hidden");
      success.classList.remove("hidden");
    }, 500);
  });
</script>
