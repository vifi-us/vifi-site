---
import { features } from "../../data/features";
import type { Feature } from "../../data/features";

interface Props {
  filter?: string[];
}

const { filter } = Astro.props;

const displayFeatures: Feature[] = filter
  ? features.filter((f) => filter.includes(f.title))
  : features;
---

<section class="pb-16 sm:pb-24">
  <div class="mx-auto max-w-5xl px-6">
    <h2
      class="text-2xl sm:text-3xl font-extrabold tracking-tight text-center mb-12"
    >
      Everything you need after the call
    </h2>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        displayFeatures.map((feature) => (
          <div class="flex items-start gap-4 rounded-2xl border border-border bg-surface p-5 transition-colors hover:border-primary/30">
            <div class="mt-0.5 shrink-0 text-primary">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d={feature.icon} />
              </svg>
            </div>
            <div>
              <h3 class="text-sm font-semibold text-text">{feature.title}</h3>
              <p class="mt-1 text-sm leading-relaxed text-muted">
                {feature.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
