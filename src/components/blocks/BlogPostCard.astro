---
interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  tags: string[];
  slug: string;
}

const { title, description, publishedAt, tags, slug } = Astro.props;

const formattedDate = publishedAt.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<a
  href={`/blog/${slug}`}
  class="block rounded-2xl border border-border bg-surface p-6 transition-colors hover:border-primary/30 group"
>
  <div class="flex items-center gap-3 mb-3">
    <time class="text-xs text-muted">{formattedDate}</time>
    {
      tags.length > 0 && (
        <div class="flex gap-2">
          {tags.map((tag) => (
            <span class="text-xs text-primary/70 bg-primary/10 rounded-full px-2 py-0.5">
              {tag}
            </span>
          ))}
        </div>
      )
    }
  </div>
  <h3 class="text-base font-semibold text-text group-hover:text-primary transition-colors mb-2">
    {title}
  </h3>
  <p class="text-sm text-muted leading-relaxed">{description}</p>
</a>
