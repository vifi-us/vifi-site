---

<section class="pb-16 sm:pb-24">
  <div class="mx-auto max-w-4xl px-6">
    <div class="text-center mb-12">
      <h2
        class="text-2xl sm:text-3xl font-extrabold tracking-tight mb-4"
      >
        What happens after the call
      </h2>
      <p class="text-base text-muted max-w-xl mx-auto">
        This is where ViFi is different. Other tools answer your calls.
        ViFi makes sure you know what happened.
      </p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2">
      {
        deliverables.map((item) => (
          <div class="rounded-2xl border border-border bg-surface p-6">
            <div class="flex items-center gap-3 mb-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-primary"
                >
                  <path d={item.icon} />
                </svg>
              </div>
              <h3 class="text-base font-semibold text-text">{item.title}</h3>
            </div>
            <p class="text-sm text-muted leading-relaxed">
              {item.description}
            </p>
          </div>
        ))
