---
const deliverables = [
  {
    icon: "M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z",
    title: "Post-call briefing",
    description:
      "A concise summary of the conversation — who called, what they need, and what requires follow-up. Read it in 30 seconds.",
  },
  {
    icon: "M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M16 13H8 M16 17H8 M10 9H8",
    title: "Full transcript",
    description:
      "The complete word-for-word record of the call. Search it, reference it, share it with your team — nothing gets lost.",
  },
  {
    icon: "M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z M19 10v2a7 7 0 0 1-14 0v-2 M12 19v3",
    title: "Call recording",
    description:
      "Listen back to any call on demand. Hear the tone, urgency, and details that text alone can't capture.",
  },
  {
    icon: "M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9 M13.73 21a2 2 0 0 1-3.46 0",
    title: "Instant notification",
    description:
      "Get alerted the moment a call ends — by text, email, or both. You're always in the loop, even when you can't answer.",
  },
