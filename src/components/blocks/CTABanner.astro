---
interface Props {
  heading: string;
  description?: string;
  buttonText?: string;
  buttonHref?: string;
}

const {
  heading,
  description,
  buttonText = "Get Early Access",
  buttonHref = "/#early-access",
} = Astro.props;
---

<section class="py-16 sm:py-24">
  <div class="mx-auto max-w-3xl px-6 text-center">
    <div
      class="rounded-2xl border border-border bg-surface p-8 sm:p-12"
    >
      <h2
        class="text-2xl sm:text-3xl font-extrabold tracking-tight leading-tight mb-4"
      >
        {heading}
      </h2>
      {
        description && (
          <p class="mx-auto max-w-lg text-base text-muted leading-relaxed mb-8">
            {description}
          </p>
        )
      }
      <a
        href={buttonHref}
        class="inline-block rounded-full bg-gradient-to-br from-primary to-secondary px-8 py-3.5 text-base font-semibold text-white shadow-[0_4px_32px_rgba(108,99,255,0.35)] transition hover:opacity-90 hover:-translate-y-0.5 hover:shadow-[0_8px_40px_rgba(108,99,255,0.45)]"
      >
        {buttonText}
      </a>
    </div>
  </div>
</section>
