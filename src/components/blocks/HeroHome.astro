---

<section class="flex flex-1 items-center py-16 sm:py-24 text-center">
  <div class="mx-auto max-w-4xl px-6">
    <div
      class="mb-8 inline-flex items-center gap-2 rounded-full border border-primary/35 bg-primary/15 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-primary/80"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-primary animate-pulse"></span>
      Coming Soon
    </div>

    <h1
      class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.1] mb-6"
    >
      Answer every call.<br />
      <span
        class="bg-gradient-to-br from-primary to-secondary bg-clip-text text-transparent"
      >
        Know every conversation.
      </span>
    </h1>

    <p class="mx-auto mb-10 max-w-xl text-base sm:text-lg text-muted leading-relaxed">
      ViFi is the AI phone assistant that handles your calls and briefs you
      after every conversation — so you never miss a lead and never call
      back blind.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#early-access"
        class="rounded-full bg-gradient-to-br from-primary to-secondary px-8 py-3.5 text-base font-semibold text-white shadow-[0_4px_32px_rgba(108,99,255,0.35)] transition hover:opacity-90 hover:-translate-y-0.5 hover:shadow-[0_8px_40px_rgba(108,99,255,0.45)]"
      >
        Get Early Access
      </a>
      <a
        href="/how-it-works"
        class="rounded-full border border-border px-8 py-3.5 text-base font-semibold text-text transition hover:border-primary/40 hover:bg-primary/5"
      >
        See how it works
      </a>
    </div>
  </div>
</section>
