---
interface Props {
  title: string;
  subtitle?: string;
  badge?: string;
}

const { title, subtitle, badge } = Astro.props;
---

<section class="pt-16 pb-12 sm:pt-24 sm:pb-16 text-center">
  <div class="mx-auto max-w-3xl px-6">
    {
      badge && (
        <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-primary/35 bg-primary/15 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-primary/80">
          {badge}
        </div>
      )
    }
    <h1
      class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight leading-[1.1] mb-4"
    >
      {title}
    </h1>
    {
      subtitle && (
        <p class="mx-auto max-w-xl text-base sm:text-lg text-muted leading-relaxed">
          {subtitle}
        </p>
      )
    }
  </div>
</section>
