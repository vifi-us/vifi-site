---
const pillars = [
  {
    icon: "M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z",
    title: "Every call gets answered",
    description:
      "Day, night, weekend, holiday. ViFi picks up so your callers never hit voicemail or a dead line.",
  },
  {
    icon: "M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M16 13H8 M16 17H8 M10 9H8",
    title: "Every conversation is documented",
    description:
      "You get a recap, a transcript, and a recording after each call. When you call back, you already know the situation.",
  },
  {
    icon: "M13 2 3 14h9l-1 10 10-12h-9l1-10z",
    title: "Live in minutes, not weeks",
    description:
      "Forward your calls to ViFi and you're up and running. No hardware, no IT team, no drawn-out onboarding.",
  },
];
---

<section class="pb-16 sm:pb-24">
  <div class="mx-auto max-w-5xl px-6">
    <div class="grid gap-6 sm:grid-cols-3">
      {
        pillars.map((pillar) => (
          <div class="rounded-2xl border border-border bg-surface p-6 text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-primary"
              >
                <path d={pillar.icon} />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-text mb-2">{pillar.title}</h3>
            <p class="text-sm text-muted leading-relaxed">
              {pillar.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
