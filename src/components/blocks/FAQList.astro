---
import { getCollection, render } from "astro:content";
import { pricingFAQs } from "../../data/pricing";

interface Props {
  category?: string;
}

const { category } = Astro.props;

const allFaqs = await getCollection("faqs");
const filteredFaqs = category
  ? allFaqs.filter((faq) => faq.data.category === category)
  : allFaqs;
const sortedFaqs = filteredFaqs.sort((a, b) => a.data.order - b.data.order);

// Pre-render all FAQ content
const renderedFaqs = await Promise.all(
  sortedFaqs.map(async (faq) => {
    const { Content } = await render(faq);
    return { faq, Content };
  })
);

// If filtering by pricing, also include inline pricing FAQs
const showPricingFAQs = category === "pricing";
---

<section class="pb-16 sm:pb-24">
  <div class="mx-auto max-w-3xl px-6">
    {
      !category && (
        <h2 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-center mb-12">
          Frequently asked questions
        </h2>
      )
    }

    <div class="space-y-3">
      {
        renderedFaqs.map(({ faq, Content }) => (
            <details class="group rounded-xl border border-border bg-surface">
              <summary class="flex cursor-pointer items-center justify-between p-5 text-sm font-semibold text-text select-none">
                {faq.data.question}
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="shrink-0 text-muted transition-transform group-open:rotate-180"
                >
                  <polyline points="6 9 12 15 18 9" />
                </svg>
              </summary>
              <div class="px-5 pb-5 text-sm text-muted leading-relaxed [&_a]:text-primary [&_a]:hover:text-secondary [&_a]:transition-colors">
                <Content />
              </div>
            </details>
          ))
      }

      {
        showPricingFAQs &&
          pricingFAQs.map((faq) => (
            <details class="group rounded-xl border border-border bg-surface">
              <summary class="flex cursor-pointer items-center justify-between p-5 text-sm font-semibold text-text select-none">
                {faq.question}
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="shrink-0 text-muted transition-transform group-open:rotate-180"
                >
                  <polyline points="6 9 12 15 18 9" />
                </svg>
              </summary>
              <div class="px-5 pb-5 text-sm text-muted leading-relaxed">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))
      }
    </div>
  </div>
</section>
