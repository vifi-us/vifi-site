---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/site/Header.astro";
import Footer from "../../components/site/Footer.astro";

export async function getStaticPaths() {
  const pages = await getCollection("legal");
  return pages.map((page) => ({
    params: { slug: page.id },
    props: { page },
  }));
}

const { page } = Astro.props;
const { Content } = await render(page);

const formattedDate = page.data.effectiveDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout
  title={`${page.data.title} | ViFi`}
  description={page.data.description}
>
  <div class="flex min-h-screen flex-col">
    <Header />
    <main class="flex-1">
      <article class="py-16 sm:py-24">
        <div class="mx-auto max-w-3xl px-6">
          <h1
            class="text-3xl sm:text-4xl font-extrabold tracking-tight leading-tight mb-4"
          >
            {page.data.title}
          </h1>
          <p class="text-sm text-muted mb-8">
            Effective: {formattedDate}
          </p>

          <div
            class="[&_p]:text-muted [&_p]:leading-relaxed [&_p]:mb-6
              [&_h2]:text-text [&_h2]:text-xl [&_h2]:sm:text-2xl [&_h2]:font-bold [&_h2]:mt-10 [&_h2]:mb-4
              [&_h3]:text-text [&_h3]:text-lg [&_h3]:font-semibold [&_h3]:mt-8 [&_h3]:mb-3
              [&_ul]:text-muted [&_ul]:space-y-2 [&_ul]:pl-6 [&_ul]:list-disc [&_ul]:mb-6
              [&_ol]:text-muted [&_ol]:space-y-2 [&_ol]:pl-6 [&_ol]:list-decimal [&_ol]:mb-6
              [&_a]:text-primary [&_a]:hover:text-secondary [&_a]:transition-colors
              [&_strong]:text-text"
          >
            <Content />
          </div>
        </div>
      </article>
    </main>
    <Footer />
  </div>

  <div class="pointer-events-none fixed inset-0 -z-10" aria-hidden="true">
    <div
      class="absolute inset-0"
      style="background: radial-gradient(ellipse 80% 50% at 20% 10%, rgba(108,99,255,0.12) 0%, transparent 60%), radial-gradient(ellipse 60% 40% at 80% 80%, rgba(0,212,170,0.10) 0%, transparent 60%);"
    >
    </div>
  </div>
</BaseLayout>
