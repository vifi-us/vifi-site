---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/site/Header.astro";
import Footer from "../../components/site/Footer.astro";
import SolutionHero from "../../components/blocks/SolutionHero.astro";
import PainPoints from "../../components/blocks/PainPoints.astro";
import FeatureHighlights from "../../components/blocks/FeatureHighlights.astro";
import CTABanner from "../../components/blocks/CTABanner.astro";
import { solutions } from "../../data/solutions";

export function getStaticPaths() {
  return solutions.map((solution) => ({
    params: { slug: solution.slug },
    props: { solution },
  }));
}

const { solution } = Astro.props;
---

<BaseLayout
  title={`ViFi for ${solution.industry} — AI Phone Assistant`}
  description={`${solution.headline}. ViFi answers calls, handles conversations, and briefs ${solution.industry.toLowerCase()} professionals after every call.`}
>
  <div class="flex min-h-screen flex-col">
    <Header />
    <main class="flex-1">
      <SolutionHero
        industry={solution.industry}
        headline={solution.headline}
        description={solution.description}
      />
      <PainPoints painPoints={solution.painPoints} />
      <FeatureHighlights filter={solution.relevantFeatures} />
      <CTABanner
        heading={`Ready to stop missing ${solution.industry.toLowerCase()} calls?`}
        description="Set up ViFi in minutes and start getting briefed after every conversation."
      />
    </main>
    <Footer />
  </div>

  <div class="pointer-events-none fixed inset-0 -z-10" aria-hidden="true">
    <div
      class="absolute inset-0"
      style="background: radial-gradient(ellipse 80% 50% at 20% 10%, rgba(108,99,255,0.12) 0%, transparent 60%), radial-gradient(ellipse 60% 40% at 80% 80%, rgba(0,212,170,0.10) 0%, transparent 60%);"
    >
    </div>
  </div>
</BaseLayout>
