---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  ogImage?: string;
}

const {
  title,
  description,
  canonicalURL = Astro.url.href,
  ogImage = "/og-default.png",
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="nightfall" data-mode="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Theme init: runs before rendering to prevent flash of wrong theme -->
    <script is:inline>
      (function () {
        var t = localStorage.getItem('vifi-theme');
        var m = localStorage.getItem('vifi-mode');
        var r = document.documentElement;
        if (t === 'shoreline' || t === 'nightfall') r.setAttribute('data-theme', t);
        if (m === 'light' || m === 'dark') r.setAttribute('data-mode', m);
        else if (window.matchMedia('(prefers-color-scheme: dark)').matches)
          r.setAttribute('data-mode', 'dark');
      })();
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta property="og:site_name" content="ViFi" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta name="generator" content={Astro.generator} />

    <!-- Analytics disabled until consent controls are implemented -->
  </head>
  <body
    class="min-h-screen bg-bg text-text font-sans antialiased overflow-x-hidden"
  >
    <slot />
  </body>
</html>
